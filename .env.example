# Copy to .env and adjust. The CLI reads DATABASE_URL.
# For local Postgres via docker-compose:
DATABASE_URL=postgres://tinybus:tinybus@localhost:5432/tinybus?sslmode=disable

# For Railway: DATABASE_URL is injected automatically when you attach the
# Postgres plugin to the service. PORT is also injected and the worker
# subcommand listens on :$PORT for /healthz when --http-addr is empty.
